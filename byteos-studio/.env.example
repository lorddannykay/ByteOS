# Sudar Studio — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# SUPABASE (Required — shared with byteos-learn)
# ============================================
# For image upload in the course editor, create a public Storage bucket named "course-media" in Supabase Dashboard.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# AUTH
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_32_char_random_string

# ============================================
# BYTEOS INTELLIGENCE SERVICE
# ============================================
BYTEOS_INTELLIGENCE_URL=http://localhost:8000

# ============================================
# AI PROVIDERS (at least one required)
# ============================================

# Together AI (recommended — cost-effective, open models)
TOGETHER_API_KEY=your_together_ai_key

# OpenAI (fallback)
OPENAI_API_KEY=your_openai_key

# Anthropic (fallback)
ANTHROPIC_API_KEY=your_anthropic_key

# ============================================
# MEDIA SEARCH APIS (for Search image in editor)
# ============================================
# Add your own keys to .env.local; never commit real keys.

# Google Custom Search (for images + content validation)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Pexels (stock photos)
PEXELS_API_KEY=

# Unsplash (professional photography)
UNSPLASH_ACCESS_KEY=

# Giphy (animated GIFs)
GIPHY_API_KEY=your_giphy_key

# ============================================
# VIDEO GENERATION
# ============================================
REMOTION_SERVER_URL=http://localhost:3040
BYTEOS_VIDEO_SERVICE_URL=http://localhost:5001

# ============================================
# RATE LIMITING (optional — defaults provided)
# ============================================
GOOGLE_SEARCH_MAX_QUERIES_PER_DAY=100
GOOGLE_SEARCH_MAX_QUERIES_PER_HOUR=30
MAX_SEARCHES_PER_VALIDATION=5

# ============================================
# LANGFUSE (optional — observability / tracing)
# ============================================
# For AI request observability. Add keys to .env.local if you use Langfuse.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=
